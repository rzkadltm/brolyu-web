# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# API base URL for the Brolyu backend
VITE_API_BASE_URL=http://localhost:3000

# WebRTC STUN/TURN server configuration
VITE_STUN_SERVER_URL=stun:stun.l.google.com:19302
VITE_TURN_SERVER_URL=
VITE_TURN_SERVER_USERNAME=
VITE_TURN_SERVER_CREDENTIAL=

# Feature flags (set to "true" to enable)
VITE_ENABLE_SCREEN_SHARE=true
VITE_ENABLE_VIDEO_CALL=true
